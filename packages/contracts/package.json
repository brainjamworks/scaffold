{
  "name": "@scaffold/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Scaffold document schema contracts consumed by OSS packages and hosted services.",
  "license": "AGPL-3.0-only",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./assessment.schema.json": "./dist/schemas/assessment.schema.json",
    "./learner-activity.schema.json": "./dist/schemas/learner-activity.schema.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vp pack src/index.ts --dts --watch",
    "test": "vp test run --passWithNoTests",
    "test:watch": "vp test watch",
    "build": "vp pack src/index.ts --dts && node scripts/generate-assessment-schema.mjs --check --copy && node scripts/generate-learner-activity-schema.mjs --check --copy",
    "generate:assessment-schema": "vp pack src/index.ts --dts && node scripts/generate-assessment-schema.mjs --write",
    "check:assessment-schema": "vp pack src/index.ts --dts && node scripts/generate-assessment-schema.mjs --check",
    "generate:learner-activity-schema": "vp pack src/index.ts --dts && node scripts/generate-learner-activity-schema.mjs --write",
    "check:learner-activity-schema": "vp pack src/index.ts --dts && node scripts/generate-learner-activity-schema.mjs --check"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "typescript": "~5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4",
    "zod-to-json-schema": "3.25.2"
  }
}
